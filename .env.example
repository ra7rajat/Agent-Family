# ─── Google AI / Vertex AI ────────────────────────────────────────────────────
# Option A – Google AI Studio key (easiest for local dev)
GOOGLE_API_KEY=AIzaSy...your_key_here

# Option B – Vertex AI (set GOOGLE_GENAI_USE_VERTEXAI=true instead of API key)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ─── Agent Configuration ──────────────────────────────────────────────────────
# Model used by the Master Agent
MASTER_MODEL=gemini-2.0-flash-lite

# Model used by sub-agents
SUB_AGENT_MODEL=gemini-2.0-flash-lite

# ─── A2A Server URLs ─────────────────────────────────────────────────────────
CALENDAR_AGENT_URL=http://localhost:8001
TASK_AGENT_URL=http://localhost:8002

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── OAuth2 (Google Calendar + Tasks API) ────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ─── Token Encryption ─────────────────────────────────────────────────────────
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# ─── Feature Flags ────────────────────────────────────────────────────────────
HITL_ENABLED=true
GOOGLE_SERVICES_ENABLED=false

# ─── Web OAuth2 Session ──────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
SESSION_TTL_DAYS=7
FRONTEND_URL=http://localhost:3000
